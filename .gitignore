# Python caches
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/

# Packaging build artifacts
/build/
/dist/
*.whl

# Generated, reproducible via scripts/make_corpus.py
/corpus/

# Trained model artifacts and compressed outputs
*.model
*.cz

# Virtualenvs
.venv/
venv/

# Real-world corpus collected locally (machine-specific)
/corpus_real/

# Local harness state
/.claude/

# Session handoff notes (kept locally, not published — may contain machine-specific paths)
/HANDOFF.md

# Credentials / secrets — never commit (defense-in-depth; tokens normally live in ~/)
.env
.env.*
*.pem
*.key
*.p12
id_rsa
id_ed25519
.pypirc
**/credentials.toml
.netrc
secrets.*

# Native build artifacts
*.so
